# ==========================================
# 1. Create the Training Script (hpo.py)
# ==========================================
%%writefile hpo.py
import torch
import torch.nn as nn
import torchvision.models as models
import torchvision.transforms as transforms
import torchvision.datasets as datasets
import argparse
import os

def train(args):
    # Image transformations for ResNet
    transform = transforms.Compose([
        transforms.Resize((224, 224)),
        transforms.ToTensor(),
        transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])
    ])
    
    try:
        # Loading dataset from S3 channel
        dataset = datasets.ImageFolder(args.data_dir, transform=transform)
        loader = torch.utils.data.DataLoader(dataset, batch_size=args.batch_size, shuffle=True)
        
        # Initialize Pre-trained ResNet18
        model = models.resnet18(pretrained=True)
        model.fc = nn.Linear(model.fc.in_features, 2) # Binary classification
        
        # Directory for saving the model artifacts
        os.makedirs(args.model_dir, exist_ok=True)
        
        # Save model
        path = os.path.join(args.model_dir, 'model.pth')
        torch.save(model.state_dict(), path)
        print(f"Model saved successfully at {path}")
        
    except Exception as e:
        print(f"Error during training execution: {e}")

if __name__ == '__main__':
    parser = argparse.ArgumentParser()
    parser.add_argument('--batch_size', type=int, default=32)
    parser.add_argument('--data_dir', type=str, default=os.environ.get('SM_CHANNEL_TRAINING'))
    parser.add_argument('--model_dir', type=str, default='/opt/ml/model')
    args, _ = parser.parse_known_args()
    train(args)

# ==========================================
# 2. SageMaker Estimator Setup
# ==========================================
import sagemaker
from sagemaker.pytorch import PyTorch

session = sagemaker.Session()
role = sagemaker.get_execution_role()
s3_data_path = "s3://sagemaker-us-east-1-510096416228/med-imaging-project/pneumonia-xray" 

estimator = PyTorch(
    entry_point="hpo.py",
    role=role,
    framework_version='1.8',
    py_version='py36',
    instance_count=1,
    instance_type='ml.m5.large',
    hyperparameters={
        "batch_size": 32
    }
)

# Launching the training job
estimator.fit({'training': s3_data_path})

# ==========================================
# 3. Model Deployment (Endpoint)
# ==========================================
# Attach to the latest training job
job_name = estimator.latest_training_job.name
attached_estimator = PyTorch.attach(job_name)

try:
    # Deploy to a real-time endpoint
    predictor = attached_estimator.deploy(
        initial_instance_count=1,
        instance_type='ml.m5.large'
    )
    print(f"Endpoint successfully deployed: {predictor.endpoint_name}")
except Exception as e:
    print(f"Deployment process failed: {e}")

